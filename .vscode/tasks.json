{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch: Overlay",
      "type": "shell",
      "command": "npx esbuild overlay/src/index.ts --bundle --format=iife --outfile=overlay/dist/overlay.js --platform=browser --watch",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$", "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5 },
        "background": { "activeOnStart": true, "beginsPattern": "\\[watch\\]", "endsPattern": "\\[watch\\] build finished" }
      },
      "presentation": { "panel": "dedicated", "reveal": "silent" }
    },
    {
      "label": "Watch: Panel",
      "type": "shell",
      "command": "npx vite build --watch",
      "options": { "cwd": "${workspaceFolder}/panel" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$", "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5 },
        "background": { "activeOnStart": true, "beginsPattern": "vite", "endsPattern": "built in" }
      },
      "presentation": { "panel": "dedicated", "reveal": "silent" }
    },
    {
      "label": "Server (port 3333)",
      "type": "shell",
      "command": "npx tsx watch ../server/index.ts",
      "options": {
        "cwd": "${workspaceFolder}/test-app",
        "env": { "STORYBOOK_URL": "http://localhost:6007" }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tsx",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": ".", "endsPattern": "Listening on" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Test App (port 5173)",
      "type": "shell",
      "command": "npx vite",
      "options": { "cwd": "${workspaceFolder}/test-app" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite-test-app",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$", "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5 },
        "background": { "activeOnStart": true, "beginsPattern": "vite", "endsPattern": "ready in" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Storybook (port 6006)",
      "type": "shell",
      "command": "npm run storybook",
      "options": { "cwd": "${workspaceFolder}/panel" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "storybook",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": "storybook", "endsPattern": "Local:" }
      },
      "presentation": { "group": "dev", "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Server v3 (port 3334)",
      "type": "shell",
      "command": "npx tsx watch ../server/index.ts",
      "options": {
        "cwd": "${workspaceFolder}/test-app-v3",
        "env": { "PORT": "3334" }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tsx-v3",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": ".", "endsPattern": "Listening on" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Test App v3 (port 5175)",
      "type": "shell",
      "command": "npx vite --port 5175",
      "options": { "cwd": "${workspaceFolder}/test-app-v3" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite-test-app-v3",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$", "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5 },
        "background": { "activeOnStart": true, "beginsPattern": "vite", "endsPattern": "ready in" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Dev: All v3",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Server v3 (port 3334)", "Test App v3 (port 5175)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Mock MCP Client",
      "type": "shell",
      "command": "npx tsx mock-mcp-client.ts",
      "options": { "cwd": "${workspaceFolder}/test-app" },
      "presentation": { "panel": "dedicated", "reveal": "always", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "Test App Astro (port 5176)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/test-app-astro" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "astro",
        "pattern": { "regexp": "^(.*error.*)$", "message": 1 },
        "background": { "activeOnStart": true, "beginsPattern": "astro", "endsPattern": "localhost" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Storybook: Test App (port 6007)",
      "type": "shell",
      "command": "npm run storybook",
      "options": { "cwd": "${workspaceFolder}/storybook-test/v8" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "storybook-test-app",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": "storybook", "endsPattern": "Local:" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Storybook 10: Test App (port 6008)",
      "type": "shell",
      "command": "npm run storybook",
      "options": { "cwd": "${workspaceFolder}/storybook-test/v10" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "storybook-test-app-v10",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": "storybook", "endsPattern": "Local:" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Server for SB10 (port 3333)",
      "type": "shell",
      "command": "npx tsx watch ../server/index.ts",
      "options": {
        "cwd": "${workspaceFolder}/test-app",
        "env": { "STORYBOOK_URL": "http://localhost:6008" }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tsx-sb10",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": ".", "endsPattern": "Listening on" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Dev: Test App",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Server (port 3333)", "Test App (port 5173)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Dev: SB8",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Server (port 3333)", "Storybook: Test App (port 6007)", "Test App (port 5173)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Dev: SB10",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Server for SB10 (port 3333)", "Storybook 10: Test App (port 6008)", "Test App (port 5173)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Server for External SB (port 3333)",
      "type": "shell",
      "command": "npx tsx watch ../server/index.ts",
      "options": {
        "cwd": "${workspaceFolder}/test-app",
        "env": { "STORYBOOK_URL": "http://localhost:6006" }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tsx-ext-sb",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": ".", "endsPattern": "Listening on" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Dev: External SB6006",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Server for External SB (port 3333)", "Test App (port 5173)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Server Angular (port 3335)",
      "type": "shell",
      "command": "npx tsx watch ../server/index.ts",
      "options": {
        "cwd": "${workspaceFolder}/test-app-angular",
        "env": { "PORT": "3335", "STORYBOOK_URL": "http://localhost:6009" }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tsx-angular",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": ".", "endsPattern": "Listening on" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Test App Angular (port 5177)",
      "type": "shell",
      "command": "npx ng serve --port 5177",
      "options": { "cwd": "${workspaceFolder}/test-app-angular" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular-dev",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": "angular", "endsPattern": "Local:" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Storybook Angular (port 6009)",
      "type": "shell",
      "command": "npm run storybook",
      "options": { "cwd": "${workspaceFolder}/storybook-test/angular-v10" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "storybook-angular",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": "storybook", "endsPattern": "Local:" }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Watch: Angular CSS",
      "type": "shell",
      "command": "npx @tailwindcss/cli -i src/tailwind.css -o src/styles.css --watch",
      "options": { "cwd": "${workspaceFolder}/test-app-angular" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tailwind-angular",
        "pattern": { "regexp": "^(Error): (.*)$", "severity": 1, "message": 2 },
        "background": { "activeOnStart": true, "beginsPattern": "tailwindcss", "endsPattern": "Done in" }
      },
      "presentation": { "panel": "dedicated", "reveal": "silent" }
    },
    {
      "label": "Dev: Angular",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Watch: Angular CSS", "Server Angular (port 3335)", "Test App Angular (port 5177)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Dev: SB Angular",
      "dependsOn": ["Watch: Overlay", "Watch: Panel", "Watch: Angular CSS", "Server Angular (port 3335)", "Storybook Angular (port 6009)", "Test App Angular (port 5177)"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
