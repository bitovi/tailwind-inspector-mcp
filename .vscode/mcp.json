{
	"servers": {
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest",
				"--browser",
				"chromium",
				"--no-sandbox",
				"--caps=vision",
				"--output-dir",
				"${workspaceFolder}/temp"
			],
			"type": "stdio"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		}
	},
	"inputs": []
}
