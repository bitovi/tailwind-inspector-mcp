{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "../../test-app-angular/src/**/*.ts",
    "../../storybook-addon/**/*.ts",
    ".storybook/**/*.ts"
  ],
  "exclude": [
    "../../storybook-addon/preview.ts",
    "../../storybook-addon/manager.tsx"
  ]
}
